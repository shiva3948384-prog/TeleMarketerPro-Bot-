rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && string(userId) == request.auth.uid;
    }
    
    function isBanned() {
      return isSignedIn() && exists(/databases/$(database)/documents/config/global) && 
             request.auth.uid in get(/databases/$(database)/documents/config/global).data.bannedUsers;
    }

    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles and stats
    match /users/{userId} {
      allow read: if isOwner(userId) && !isBanned();
      allow write: if false; // Only server can write user stats/branding
    }

    // Linked Accounts
    match /accounts/{phone} {
      allow read: if isSignedIn() && !isBanned() && resource.data.userId == int(request.auth.uid);
      allow write: if false; // Only server handles sessions and accounts
    }

    // Ad Templates
    match /templates/{templateId} {
      allow read: if isSignedIn() && !isBanned() && resource.data.userId == int(request.auth.uid);
      allow write: if isSignedIn() && !isBanned() && 
                    (request.resource.data.userId == int(request.auth.uid) || resource.data.userId == int(request.auth.uid));
    }

    // Global Config
    match /config/global {
      allow read: if isSignedIn(); // Users need to see if they are admin/banned
      allow write: if false; // Server only
    }
  }
}
